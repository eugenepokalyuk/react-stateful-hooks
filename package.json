{
  "name": "react-stateful-hooks",
  "version": "0.2.1",
  "description": "A small, well-typed collection of SSR-safe React hooks for browser state: persisted storage with cross-tab sync, debounced values, and media queries",
  "type": "module",
  "license": "MIT",
  "author": "Evgenii Pokalyuk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugenepokalyuk/react-stateful-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/eugenepokalyuk/react-stateful-hooks/issues"
  },
  "homepage": "https://eugenepokalyuk.github.io/react-stateful-hooks/",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "hooks",
    "react-hooks",
    "localstorage",
    "sessionstorage",
    "usestate",
    "ssr",
    "ssr-safe",
    "hydration",
    "nextjs",
    "remix",
    "usesyncexternalstore",
    "typescript",
    "cross-tab",
    "debounce",
    "matchmedia"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/use-sync-external-store": "^0.0.6",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "prettier": "3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "use-sync-external-store": "^1.6.0"
  }
}
